@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rno: <https://regnskapnoter-taxonomy/regnskap-no/> .

rno:ConceptShape
    a sh:NodeShape ;
    sh:targetClass skos:Concept ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:datatype rdf:langString ;
        sh:uniqueLang true ;
    ] ;
    sh:property [
        sh:path skos:inScheme ;
        sh:minCount 1 ;
    ] .

rno:RegnskapNoConceptShape
    a sh:NodeShape ;
    sh:targetSubjectsOf rno:periodType ;
    sh:property [
        sh:path rno:periodType ;
        sh:in ( "instant" "duration" ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rno:status ;
        sh:in ( "candidate" "standard" "deprecated" "retired" ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rno:balance ;
        sh:in ( "debit" "credit" ) ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rno:dataType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .

rno:CalculationArcShape
    a sh:NodeShape ;
    sh:targetClass rno:CalculationArc ;
    sh:property [
        sh:path rno:weight ;
        sh:in ( -1 1 ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .
