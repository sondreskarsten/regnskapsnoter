      {
        "@value": "regnskap-no:SkattefunnGodkjent"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "nb",
        "@value": "SkatteFUNN-prosjekt godkjent"
      },
      {
        "@language": "en",
        "@value": "SkatteFUNN project approved"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/abstract": [
      {
