  {
    "@id": "https://regnskapnoter-taxonomy/regnskap-no/UtsattSkattSatsPct",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://xbrl.ifrs.org/taxonomy/ifrs-full/AverageEffectiveTaxRate"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "nb",
        "@value": "Regnskapsføring av resultatskatt omfatter alle regnskapspliktige som er skattepliktige som eget skattesubjekt. Ved investering i datterselskap og tilknyttet selskap vil det kunne oppstå utsatt skatt selv om investor eller det selskap som det er investert i ikke regnskapsfører utsatt skatt. Det samme gjelder ved deltakelse i felles kontrollert virk- somhet. Standarden omhandler regnskapsføring av resultatskatt både i selskapsregn- skapet og konsernregnskapet. Utsatt skatt ble innført i norske regnskaper ved endring i regnskapslovgivningen i 1992. NOU 1992:13 og NOU 1995:30 med tilhørende Odelstingsproposisjoner og inn- stillinger er grunnlaget for utvikling av god regnskapsskikk ved regnskapsføring av skatt på resultat. 2. Drøftelse 2.1 Begreper og sammenhenger Skatt behandles som en kostnad og regnskapsføring av utsatt skatt følger av sammen- stillingsprinsippet, jf. § 4-1 nr 3 i regnskapsloven. Skattekostnaden består av betalbar skatt på skattemessig resultat og skattevirkningen av midlertidige resultatforskjeller og underskudd til fremføring. Skattekostnaden vil dermed bli sammenstilt med det regn- skapsmessige resultat før skatt. Betalbar skatt beregnes på grunnlag av skattemess..."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://regnskapnoter-taxonomy/regnskap-no/Scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "regnskap-no:UtsattSkattSatsPct"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "nb",
        "@value": "Utsatt skatt - skattesats"
      },
      {
        "@language": "en",
        "@value": "Deferred tax rate"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/abstract": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#boolean",
        "@value": false
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/dataType": [
      {
        "@value": "percentItemType"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/introducedVersion": [
      {
        "@value": "0.1.0"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/periodType": [
      {
        "@value": "instant"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/status": [
      {
        "@value": "standard"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/substitutionGroup": [
      {
        "@value": "item"
      }
    ]
  },
  {
    "@id": "https://regnskapnoter-taxonomy/regnskap-no/GodtgjorelseDagligLederBonusBelop",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://xbrl.ifrs.org/taxonomy/ifrs-full/KeyManagementPersonnelCompensationShorttermEmployeeBenefits"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "nb",
        "@value": "Lån og sikkerhetsstillelse til ledende personer, aksjeeiere m.v. Det skal opplyses om samlede lån til og samlet sikkerhetsstillelse til fordel for medlemmer av styret med angivelse av rentesats, hovedvilkår og eventuelle tilbakebetalte, avskrevne eller frafalte beløp. Det samme gjelder for medlemmer av annet administrasjons-, ledelses- eller kontrollorgan."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
