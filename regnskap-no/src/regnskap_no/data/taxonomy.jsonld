  {
    "@id": "https://regnskapnoter-taxonomy/regnskap-no/StyresignaturNavn",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "nb",
        "@value": "Regnskapsloven § 3-5 — Underskrift: Årsregnskapet og årsberetningen skal underskrives av samtlige styremedlemmer og av daglig leder. Har en av disse innvendinger mot årsregnskapet eller årsberetningen, skal vedkommende underskrive med påtegnet forbehold og gi nærmere redegjørelse i årsberetningen."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://regnskapnoter-taxonomy/regnskap-no/Scheme"
      }
    ],
