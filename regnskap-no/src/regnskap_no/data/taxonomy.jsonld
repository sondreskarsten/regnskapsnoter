  {
    "@id": "https://regnskapnoter-taxonomy/regnskap-no/SkattefunnForventetTilskudd",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "nb",
        "@value": "Skatteloven § 16-40 — Fradrag i skatt for kostnader til forskning og utvikling (SkatteFUNN): Skattyter som driver virksomhet, gis fradrag i skatt og trygdeavgift for kostnader til forsknings- og utviklingsprosjekt etter bestemmelsene i denne paragraf. Forskningsrådet skal forhåndsgodkjenne prosjektet for at fradrag skal innrømmes."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://regnskapnoter-taxonomy/regnskap-no/Scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "regnskap-no:SkattefunnForventetTilskudd"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "nb",
        "@value": "SkatteFUNN - forventet tilskudd"
      },
      {
        "@language": "en",
        "@value": "SkatteFUNN - expected grant"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/abstract": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#boolean",
        "@value": false
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/balance": [
      {
        "@value": "credit"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/dataType": [
      {
        "@value": "monetaryItemType"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/introducedVersion": [
      {
        "@value": "0.1.0"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/periodType": [
      {
        "@value": "duration"
      }
    ],
