  {
    "@id": "https://regnskapnoter-taxonomy/regnskap-no/DriftsinntektVirksomhetsomraade",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://xbrl.ifrs.org/taxonomy/ifrs-full/RevenueFromContractsWithCustomers"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "nb",
        "@value": "Sammenslåing av poster i oppstillingsplanen (1) Poster i oppstillingsplanen som er slått sammen etter § 6-3 annet ledd, skal spesifiseres. (2) § 6-6 om sammenligningstall gjelder tilsvarende."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
