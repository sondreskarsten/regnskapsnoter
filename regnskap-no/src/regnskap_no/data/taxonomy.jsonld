      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "nb",
        "@value": "Godtgjørelse revisor andre tjenester"
      },
      {
        "@language": "en",
        "@value": "Audit fees — other services"
      }
    ],
