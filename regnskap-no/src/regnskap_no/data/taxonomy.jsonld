      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "nb",
        "@value": "Beskrivelse av forventet levetid"
      },
      {
        "@language": "en",
        "@value": "Description of useful life"
      }
    ],
