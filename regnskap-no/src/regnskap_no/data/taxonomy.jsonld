      {
        "@value": "regnskap-no:OverordnetMorselskapNavn"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "nb",
        "@value": "Navn på overordnet morselskap"
      },
      {
        "@language": "en",
        "@value": "Name of ultimate parent"
      }
    ],
