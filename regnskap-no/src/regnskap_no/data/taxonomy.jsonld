  {
    "@id": "https://regnskapnoter-taxonomy/regnskap-no/GjeldForfallOver5Ar",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://xbrl.ifrs.org/taxonomy/ifrs-full/NoncurrentLiabilities"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "nb",
        "@value": "Fordringer, gjeld, garantiforpliktelser (1) Det skal opplyses hvor stor del av den regnskapspliktiges fordringer som forfaller senere enn ett år etter regnskapsårets slutt. (2) Det skal opplyses hvor stor del av den regnskapspliktiges gjeld som forfaller til betaling mer enn fem år etter regnskapsårets slutt, hvor stor del av den regnskapspliktiges gjeld som er sikret ved pant eller lignende sikkerhet i den regnskapspliktiges eiendeler, og balanseført verdi av de pantsatte eiendeler. (3) Det skal opplyses om summen av garantiforpliktelser som ikke er regnskapsført. Det skal opplyses særskilt dersom slike garantiforpliktelser er sikret ved pant."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://regnskapnoter-taxonomy/regnskap-no/Scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "regnskap-no:GjeldForfallOver5Ar"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "nb",
        "@value": "Gjeld med forfall etter mer enn fem år"
      },
      {
        "@language": "en",
        "@value": "Debt falling due after more than 5 years"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/abstract": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#boolean",
        "@value": false
      }
    ],
