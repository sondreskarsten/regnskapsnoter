  {
    "@id": "https://regnskapnoter-taxonomy/regnskap-no/v0.1.0/EndringRegnskapsprinsippBeskrivelse",
    "http://purl.org/dc/terms/hasVersion": [
      {
        "@value": "0.1.0"
      }
    ],
    "http://purl.org/dc/terms/isVersionOf": [
      {
        "@id": "https://regnskapnoter-taxonomy/regnskap-no/EndringRegnskapsprinsippBeskrivelse"
      }
    ],
