      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/substitutionGroup": [
      {
        "@value": "item"
      }
    ]
  },
  {
    "@id": "https://regnskapnoter-taxonomy/regnskap-no/AnleggsmiddelOkonomiskLevetid",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://xbrl.ifrs.org/taxonomy/ifrs-full/UsefulLifeMeasuredAsPeriodOfTimePropertyPlantAndEquipment"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "nb",
        "@value": "Anleggsmidler (1) For varige driftsmidler og immaterielle eiendeler skal det opplyses om: 1. anskaffelseskost med spesifikasjon av balanseførte lånekostnader knyttet til egentilvirkede anleggsmidler, 2. tilgang og avgang i løpet av regnskapsåret, 3. samlede avskrivninger, nedskrivninger og reverseringer av nedskrivninger, og 4. avskrivninger, nedskrivninger og reverseringer av nedskrivninger i regnskapsåret. (2) Det skal opplyses om økonomisk levetid og valg av avskrivningsplan for immaterielle eiendeler. (3) Goodwill skal spesifiseres for hvert enkelt virksomhetskjøp. Avskrivningsplan for goodwill som er lenger enn fem år, skal begrunnes."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://regnskapnoter-taxonomy/regnskap-no/Scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "regnskap-no:AnleggsmiddelOkonomiskLevetid"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "nb",
        "@value": "Økonomisk levetid"
      },
      {
        "@language": "en",
        "@value": "Economic useful life"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/abstract": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#boolean",
        "@value": false
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/dataType": [
      {
        "@value": "decimalItemType"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/introducedVersion": [
      {
        "@value": "0.1.0"
      }
    ],
