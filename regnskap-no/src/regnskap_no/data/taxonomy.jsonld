      {
        "@value": "regnskap-no:BokfortVerdiPantsattEiendel"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "nb",
        "@value": "Bokført verdi pantsatte eiendeler"
      },
      {
        "@language": "en",
        "@value": "Carrying amount of pledged assets"
      }
    ],
