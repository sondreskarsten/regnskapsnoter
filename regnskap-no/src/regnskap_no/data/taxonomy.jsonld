      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "nb",
        "@value": "Virkning av endring av regnskapsprinsipp m.v. Det skal opplyses om virkningen av endring av regnskapsprinsipp. Det samme gjelder feil i tidligere årsregnskap og korrigering av slike feil, samt omklassifiseringer. Sammenligningstall og omarbeiding av disse skal forklares."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
