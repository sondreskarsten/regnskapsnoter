  {
    "@id": "https://regnskapnoter-taxonomy/regnskap-no/BundneSkattetrekksmidler",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "nb",
        "@value": "Bundne skattetrekksmidler etter skattebetalingsloven § 5-12: Den som gjør fradrag i lønn for forskuddstrekk, skal sette beløpet inn på særskilt bankkonto (skattetrekkskonto) hver gang det utbetales lønn. I stedet for innskudd på skattetrekkskonto kan det stilles bankgaranti for trekkbeløpet, eller midlene kan være sikret på annen måte godtatt av skatteoppkreveren."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://regnskapnoter-taxonomy/regnskap-no/Scheme"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#notation": [
      {
        "@value": "regnskap-no:BundneSkattetrekksmidler"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#prefLabel": [
      {
        "@language": "nb",
        "@value": "Bundne skattetrekksmidler"
      },
      {
        "@language": "en",
        "@value": "Restricted withholding tax funds"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/abstract": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#boolean",
        "@value": false
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/balance": [
      {
        "@value": "debit"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/dataType": [
      {
        "@value": "monetaryItemType"
      }
    ],
