      {
        "@language": "nb",
        "@value": "Oppfyller OTP-krav"
      },
      {
        "@language": "en",
        "@value": "Complies with OTP requirements"
      }
    ],
    "https://regnskapnoter-taxonomy/regnskap-no/abstract": [
