  {
    "@id": "https://regnskapnoter-taxonomy/regnskap-no/PensjonsforpliktelserNetto",
    "@type": [
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://www.w3.org/2004/02/skos/core#closeMatch": [
      {
        "@id": "https://xbrl.ifrs.org/taxonomy/ifrs-full/NetDefinedBenefitLiabilityAsset"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "nb",
        "@value": "4. Standarden omhandler regnskapsføring ved normal oppfølging og oppfyllelse av pensjonsplaner. Standarden omhandler også oppgjør eller vesentlig avkorting av pensjonsplan. 4A. Som et alternativ til den regnskapsføring som følger av standardens hovedregler, åpnes det i henholdsvis punkt 67 og 68 for anvendelse av målereglene og reglene om resultatspesifikasjon i IAS 19 og US GAAP. 1 NRS 6 Pensjonskostnader Pensjonsordninger i Norge Finansiering direkte over drift"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://regnskapnoter-taxonomy/regnskap-no/Scheme"
