    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:UtsattSkattSatsPct" ;
    skos:prefLabel "Deferred tax rate"@en,
        "Utsatt skatt - skattesats"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:dataType "percentItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
