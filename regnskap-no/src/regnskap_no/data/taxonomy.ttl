regnskap-no:AvskrivningVarigeDriftsmidlerOgImmaterielleEiendeler a skos:Concept ;
    skos:broader regnskap-no:Driftsresultat ;
    skos:definition "7. Avskrivning på varige driftsmidler og immaterielle eiendeler"@nb ;
