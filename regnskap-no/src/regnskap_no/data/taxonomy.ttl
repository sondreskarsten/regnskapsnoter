    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

regnskap-no:AnleggsmidlerEndringAxis a skos:Concept,
        regnskap-no:Axis ;
    skos:closeMatch ifrs-full:CarryingAmountAccumulatedDepreciationAmortisationAndImpairmentAndGrossCarryingAmountAxis ;
    skos:inScheme regnskap-no:Scheme ;
    skos:narrower regnskap-no:AkkumulerteAvskrivningerInngaendeMember,
        regnskap-no:AnskaffelseskostInngaendeMember,
