regnskap-no:InntektsforingMetodeBeskrivelse a skos:Concept ;
    skos:closeMatch ifrs-full:DescriptionOfAccountingPolicyForRecognitionOfRevenueExplanatory ;
    skos:definition "Salgsinntekter Salgsinntekter skal spesifiseres på virksomhetsområde og geografisk marked."@nb ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:InntektsforingMetodeBeskrivelse" ;
