    skos:broader regnskap-no:FinansielleAnleggsmidler ;
    skos:closeMatch ifrs-full:NetDefinedBenefitAsset ;
    skos:definition "A. Anleggsmidler — III. Finansielle anleggsmidler — 8. Andre fordringer"@nb ;
    skos:inScheme regnskap-no:Scheme ;
