    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:KontingentForpliktelseBelop" ;
    skos:prefLabel "Contingent liability - amount"@en,
        "Kontingent forpliktelse - beløp"@nb ;
