    regnskap-no:abstract false ;
    regnskap-no:balance "credit" ;
    regnskap-no:dataType "monetaryItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "instant" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

regnskap-no:BetalbarSkattAaret a skos:Concept ;
    skos:definition "Andre forpliktelser Det skal opplyses om andre forpliktelser enn nevnt i § 7-28 som ikke er regnskapsført. Det skal opplyses særskilt dersom slike forpliktelser er sikret ved pant."@nb ;
    skos:exactMatch ifrs-full:CurrentTaxExpenseIncome ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:BetalbarSkattAaret" ;
