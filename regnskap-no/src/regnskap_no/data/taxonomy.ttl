regnskap-no:PensjonsforpliktelserNetto a skos:Concept ;
    skos:closeMatch ifrs-full:NetDefinedBenefitLiabilityAsset ;
    skos:definition "4. Standarden omhandler regnskapsføring ved normal oppfølging og oppfyllelse av pensjonsplaner. Standarden omhandler også oppgjør eller vesentlig avkorting av pensjonsplan. 4A. Som et alternativ til den regnskapsføring som følger av standardens hovedregler, åpnes det i henholdsvis punkt 67 og 68 for anvendelse av målereglene og reglene om resultatspesifikasjon i IAS 19 og US GAAP. 1 NRS 6 Pensjonskostnader Pensjonsordninger i Norge Finansiering direkte over drift"@nb ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:PensjonsforpliktelserNetto" ;
    skos:prefLabel "Net pension obligation"@en,
        "Pensjonsforpliktelser netto"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:balance "credit" ;
    regnskap-no:dataType "monetaryItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "instant" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

regnskap-no:PensjonskostnadDB a skos:Concept ;
    skos:closeMatch ifrs-full:PostemploymentBenefitExpenseDefinedBenefitPlans ;
    skos:definition "5. Utbetaling av pensjoner finansieres gjennom foretakets ordinære drift. Det er i utgangspunktet ikke øremerket særskilte eiendeler for finansiering og sikring av pensjonsforpliktelsene. Pensjonsytelser over drift kan imidlertid sikres helt eller delvis gjennom ulike former for sikkerhetsstillelser. Slike pensjonsforpliktelser er likevel ofte usikret. Finansiering ved fondsopplegg"@nb ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:PensjonskostnadDB" ;
    skos:prefLabel "Pension cost - defined benefit"@en,
        "Pensjonskostnad ytelsesordning"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:balance "debit" ;
    regnskap-no:dataType "monetaryItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "duration" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

regnskap-no:PensjonskostnadDC a skos:Concept ;
    skos:definition "5. Utbetaling av pensjoner finansieres gjennom foretakets ordinære drift. Det er i utgangspunktet ikke øremerket særskilte eiendeler for finansiering og sikring av pensjonsforpliktelsene. Pensjonsytelser over drift kan imidlertid sikres helt eller delvis gjennom ulike former for sikkerhetsstillelser. Slike pensjonsforpliktelser er likevel ofte usikret. Finansiering ved fondsopplegg"@nb ;
    skos:exactMatch ifrs-full:PostemploymentBenefitExpenseDefinedContributionPlans ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:PensjonskostnadDC" ;
