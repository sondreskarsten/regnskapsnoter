    regnskap-no:periodType "duration" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

regnskap-no:OpptjentIkkeFakturert a skos:Concept ;
    skos:closeMatch ifrs-full:ContractAssets ;
    skos:definition "4. Begrepet anleggskontrakt gjelder ikke utelukkende det som i dagligtale omtales som anleggsvirksomhet (for eksempel bygging av vei eller tunnel), men også andre byggeoppdrag, skipsbygging og tilvirkning av store og komplekse produk- ter eller leveranser. Kontraktsfestet tjenesteyting knyttet til anleggsvirksomhet, eksempelvis byggeledelse, teknisk assistanse eller arkitektoppdrag, omfattes også."@nb ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:OpptjentIkkeFakturert" ;
    skos:prefLabel "Recognized but uninvoiced production"@en,
        "Opptjent ikke fakturert produksjon"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:balance "debit" ;
    regnskap-no:dataType "monetaryItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "instant" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

