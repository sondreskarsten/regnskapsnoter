regnskap-no:FremforbartUnderskudd a skos:Concept ;
    skos:closeMatch ifrs-full:UnusedTaxLossesForWhichNoDeferredTaxAssetRecognised ;
    skos:definition "Skatteloven § 14-6 — Underskudd: Underskudd ved virksomhet kan kreves fradratt i skattyterens inntekt i senere år. Underskuddet skal fradras så langt det er skattepliktig inntekt, og skal anvendes uten unødig opphold. Underskudd faller ikke bort etter en bestemt tidsfrist."@nb ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:FremforbartUnderskudd" ;
    skos:prefLabel "Carry-forward losses"@en,
        "Fremførbart underskudd"@nb ;
