regnskap-no:OverordnetMorselskapNavn a skos:Concept ;
    skos:definition "Finansiell markedsrisiko (1) Det skal gis opplysninger om egenskaper ved og omfang av finansielle derivater fordelt på klasser av derivater. Opplysningene skal omfatte vesentlige betingelser og forhold som kan påvirke beløpsstørrelse, tidfesting og usikkerhet ved fremtidige kontantstrømmer. (2) Foretak av allmenn interesse skal gi opplysninger om finansiell markedsrisiko fordelt på arter av risiko."@nb ;
    skos:exactMatch ifrs-full:NameOfUltimateParentOfGroup ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:OverordnetMorselskapNavn" ;
    skos:prefLabel "Name of ultimate parent"@en,
        "Navn på overordnet morselskap"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:dataType "stringItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "instant" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

regnskap-no:PantsatteEiendelerBeskrivelse a skos:Concept ;
    skos:closeMatch ifrs-full:DescriptionOfNatureAndCarryingAmountOfAssetsPledgedAsCollateralForLiabilities ;
    skos:definition "Fordringer, gjeld, garantiforpliktelser (1) Det skal opplyses hvor stor del av den regnskapspliktiges fordringer som forfaller senere enn ett år etter regnskapsårets slutt. (2) Det skal opplyses hvor stor del av den regnskapspliktiges gjeld som forfaller til betaling mer enn fem år etter regnskapsårets slutt, hvor stor del av den regnskapspliktiges gjeld som er sikret ved pant eller lignende sikkerhet i den regnskapspliktiges eiendeler, og balanseført verdi av de pantsatte eiendeler. (3) Det skal opplyses om summen av garantiforpliktelser som ikke er regnskapsført. Det skal opplyses særskilt dersom slike garantiforpliktelser er sikret ved pant."@nb ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:PantsatteEiendelerBeskrivelse" ;
    skos:prefLabel "Description of pledged assets"@en,
        "Beskrivelse av pantsatte eiendeler"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:dataType "textBlockItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "instant" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

