        regnskap-no:AretsReverseringNedskrivningMember,
        regnskap-no:AvgangMember,
        regnskap-no:BalansefortVerdiUtgaendeMember,
        regnskap-no:TilgangMember ;
    skos:notation "regnskap-no:AnleggsmidlerEndringAxis" ;
    skos:prefLabel "Changes in non-current assets"@en,
        "Endringer i anleggsmidler"@nb ;
    regnskap-no:axisKind "explicit" .

regnskap-no:ResultatForSkattekostnad a skos:Concept ;
    skos:broader regnskap-no:Aarsresultat ;
    skos:definition "19. Resultat før skattekostnad"@nb ;
    skos:exactMatch ifrs-full:ProfitLossBeforeTax ;
