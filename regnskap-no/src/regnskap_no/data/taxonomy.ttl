regnskap-no:AdministrativeKostnader a skos:Concept ;
    skos:broader regnskap-no:DriftsresultatFunksjon ;
    skos:definition "5. Administrative kostnader"@nb ;
    skos:exactMatch ifrs-full:AdministrativeExpense ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:AdministrativeKostnader" ;
    skos:prefLabel "Administrative expenses"@en,
        "Administrative kostnader"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:balance "debit" ;
    regnskap-no:dataType "monetaryItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "duration" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

regnskap-no:Aksjekapital a skos:Concept ;
    skos:broader regnskap-no:InnskuttEgenkapital ;
    skos:definition "C. Egenkapital — I. Innskutt egenkapital — 1. Selskapskapital"@nb ;
    skos:exactMatch ifrs-full:IssuedCapital ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:Aksjekapital" ;
    skos:prefLabel "Share capital"@en,
        "Aksjekapital"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:balance "credit" ;
    regnskap-no:dataType "monetaryItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "instant" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

regnskap-no:AksjekapitalAntallAksjer a skos:Concept ;
    skos:definition "Antall aksjer, aksjeeiere m.v. (1) Har selskapet en beholdning av egne aksjer etter aksjeloven kapittel 9 , skal det opplyses om antallet, aksjenes pålydende verdi og den andel aksjene utgjør av aksjekapitalen. (2) Det skal opplyses om endringer i beholdning av egne aksjer og datterselskapenes beholdning av aksjer i morselskapet i løpet av regnskapsåret. Det skal minst opplyses om: 1. bakgrunnen for erverv som har funnet sted, 2. antall aksjer som er ervervet, vederlag for disse og den andel de utgjør av aksjekapitalen, 3. antall aksjer som er avhendet, vederlag for disse og den andel de utgjør av aksjekapitalen. (3) Samvirkeforetak som har medlemskapitalkonti i samsvar med lov om samvirkeforetak § 29 , skal gi opplysninger om årets utbetaling og avsetning. Det skal også opplyses om eventuelle vedtektsbestemmelser og årsmøtevedtak eller forslag til vedtak knyttet til medlemskapitalkonti."@nb ;
    skos:exactMatch ifrs-full:NumberOfSharesIssued ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:AksjekapitalAntallAksjer" ;
    skos:prefLabel "Number of shares"@en,
        "Antall aksjer"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:dataType "sharesItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "instant" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

regnskap-no:AksjekapitalAntallAksjerKlasse a skos:Concept ;
    skos:closeMatch ifrs-full:NumberOfSharesIssued ;
    skos:definition "Antall aksjer, aksjeeiere m.v. (1) Aksjeselskap og allmennaksjeselskap skal opplyse om aksjekapitalen og aksjenes pålydende fordelt på hver aksjeklasse. Det skal opplyses om vedtektsbestemmelser om stemmerett. Det skal opplyses om alle rettigheter som kan medføre at det blir utstedt nye aksjer med angivelse av hovedtrekkene i de vilkår som gjelder for retten. (2) Aksjeselskap og allmennaksjeselskap skal opplyse om selskapets 20 største aksjeeiere og deres eierandeler. Opplysning om aksjeeiere som eier under 1 prosent av aksjene kan utelates. (3) Det skal opplyses om aksjer eller andeler i selskapet samt rettigheter til slike, som eies av henholdsvis daglig leder og medlemmer av styret og bedriftsforsamlingen. (4) Foretak av allmenn interesse skal gi opplysninger som nevnt i tredje ledd spesifisert på de enkelte medlemmer av styret og deres personlig nærstående samt de enkelte ledende ansatte og deres personlig nærstående. Som personlig nærstående regnes: 1. ektefelle og en person som vedkommende bor sammen med i ekteskapslignende forhold, 2. mindreårige barn til vedkommende selv, samt mindreårige barn til en person som nevnt i nr. 1 som vedkommende bor sammen med, og 3. foretak der vedkommende selv eller noen som er nevnt i nr. 1 og 2 har slik bestemmende innflytelse som nevnt i § 1-3 annet ledd. (5) Regnskapspliktige som er utstedere med Norge som hjemstat etter verdipapirhandelloven § 5-4 , skal opplyse om vesentlige indirekte aksjebesittelser i selskapet. Aksjebesittelser ..."@nb ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:AksjekapitalAntallAksjerKlasse" ;
    skos:prefLabel "Number of shares by class"@en,
        "Antall aksjer per klasse"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:dataType "sharesItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "instant" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

regnskap-no:AksjekapitalPalydendeVerdi a skos:Concept ;
    skos:definition "Antall aksjer, aksjeeiere m.v. (1) Har selskapet en beholdning av egne aksjer etter aksjeloven kapittel 9 , skal det opplyses om antallet, aksjenes pålydende verdi og den andel aksjene utgjør av aksjekapitalen. (2) Det skal opplyses om endringer i beholdning av egne aksjer og datterselskapenes beholdning av aksjer i morselskapet i løpet av regnskapsåret. Det skal minst opplyses om: 1. bakgrunnen for erverv som har funnet sted, 2. antall aksjer som er ervervet, vederlag for disse og den andel de utgjør av aksjekapitalen, 3. antall aksjer som er avhendet, vederlag for disse og den andel de utgjør av aksjekapitalen. (3) Samvirkeforetak som har medlemskapitalkonti i samsvar med lov om samvirkeforetak § 29 , skal gi opplysninger om årets utbetaling og avsetning. Det skal også opplyses om eventuelle vedtektsbestemmelser og årsmøtevedtak eller forslag til vedtak knyttet til medlemskapitalkonti."@nb ;
    skos:exactMatch ifrs-full:ParValuePerShare ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:AksjekapitalPalydendeVerdi" ;
    skos:prefLabel "Par value per share"@en,
        "Pålydende verdi per aksje"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:dataType "decimalItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "instant" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

