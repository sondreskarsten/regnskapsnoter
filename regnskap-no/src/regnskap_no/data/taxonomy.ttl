regnskap-no:KonsolideringsmetodeBeskrivelse a skos:Concept ;
    skos:closeMatch ifrs-full:DescriptionOfBasisOfConsolidation ;
    skos:definition "Virkelig verdi av finansielle instrumenter For hver kategori av finansielle instrumenter og varederivater som er vurdert etter § 5-8 , skal det opplyses om virkelig verdi og periodens resultatførte verdiendring. Det skal i tillegg gis opplysninger om vesentlige opplysninger som ligger til grunn for vurderingen."@nb ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:KonsolideringsmetodeBeskrivelse" ;
    skos:prefLabel "Consolidation method description"@en,
        "Beskrivelse av konsolideringsmetode"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:dataType "textBlockItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "duration" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

