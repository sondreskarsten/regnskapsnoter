    skos:definition "D. Gjeld — III. Kortsiktig gjeld"@nb ;
    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:KortsiktigGjeld" ;
    skos:prefLabel "Current liabilities"@en,
        "Kortsiktig gjeld"@nb ;
    regnskap-no:abstract false ;
    regnskap-no:balance "credit" ;
    regnskap-no:dataType "monetaryItemType" ;
    regnskap-no:introducedVersion "0.1.0" ;
    regnskap-no:periodType "instant" ;
    regnskap-no:status "standard" ;
    regnskap-no:substitutionGroup "item" .

regnskap-no:ResultatForSkattekostnadFunksjon a skos:Concept ;
    skos:broader regnskap-no:AarsresultatFunksjon ;
    skos:definition "14. Resultat før skattekostnad"@nb ;
    skos:exactMatch ifrs-full:ProfitLossBeforeTax ;
