    skos:inScheme regnskap-no:Scheme ;
    skos:notation "regnskap-no:InternSalgsinntekterVarekostnad" ;
    skos:prefLabel "Inter-company sales and COGS"@en,
        "Interne salgsinntekter og varekostnad"@nb ;
